{% set pageTitle = seo.meta_title or title or metadata.title or "Bear Limo — Luxury Chauffeur & Limo Service" %}
{% set pageDesc = seo.meta_description or description or metadata.description or "Premium nationwide luxury chauffeur, black car, and limousine service." %}

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>{{ pageTitle }}</title>
<meta name="description" content="{{ pageDesc }}">
<meta name="robots" content="index, follow">
<link rel="canonical" href="https://www.bearlimo.com{{ page.url }}">

{% include "jsonLd.njk" %}

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDesc }}">
<meta property="og:site_name" content="Bear Limo">
<meta property="og:url" content="https://www.bearlimo.com{{ page.url }}">
<meta property="og:image" content="https://www.bearlimo.com/assets/img/og-image.jpg">
<meta property="og:image:secure_url" content="https://www.bearlimo.com/assets/img/og-image.jpg">
<meta property="og:image:type" content="image/jpeg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Bear Limo luxury chauffeur service">

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDesc }}">