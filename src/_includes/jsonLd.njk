<script type="application/ld+json">
{
  "@type":"LocalBusiness",
  "@id":"https://www.bearlimo.com/#business",

  {% if location %}
  "name":"Bear Limo – {{ location.data.title }}",
  {% else %}
  "name":"Bear Limo",
  {% endif %}

  "url":"https://www.bearlimo.com{{ page.url }}",
  "telephone":"{{ settings.top_bar.phone }}",
  "email":"{{ settings.top_bar.email }}",

  "address":{
    "@type":"PostalAddress",
    "streetAddress":"32 Peachtree St NW",
    "addressLocality":"Atlanta",
    "addressRegion":"GA",
    "postalCode":"30303",
    "addressCountry":"US"
  },

  {% if location %}
  "areaServed":{
    "@type":"City",
    "name":"{{ location.data.title }}"
  },
  {% else %}
  "areaServed":[
    {% for city in collections.locations %}
    {
      "@type":"City",
      "name":"{{ city.data.title }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  {% endif %}

  "image":"https://www.bearlimo.com/assets/img/hero.webp"
}
</script>