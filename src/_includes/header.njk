    <header class="header" role="banner">
      <!-- High-Visibility Top Utility Bar -->
<!-- Balanced Top Utility Bar -->
<!-- Responsive Balanced Top Utility Bar -->
<style>
  @media (max-width: 768px) {
    .desktop-top-bar {
      display: none !important;
    }
  }
</style>

<div class="top-bar desktop-top-bar" style="background: #ffffff; border-bottom: 1px solid var(--line, #eaeaea); padding: 10px 0; font-size: 0.85rem; font-weight: 700;">
  <div class="container" style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px;">
    
    <!-- Left Item: Phone Number -->
    <div style="text-align: left;">
      <a href="tel:+14044244499" style="color: #111111; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; font-weight: 700;">
        <span style="font-size: 1rem; line-height: 1; font-weight: 400;">📞</span> (404) 424-4499
      </a>
    </div>

    <!-- Middle Item: Email Button -->
    <div style="text-align: center;">
      <a href="mailto:info@grandlimousine.com" style="color: #111111; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; font-weight: 700;">
        <span style="font-size: 1rem; line-height: 1; font-weight: 400;">✉️</span>  info@grandlimousine.com
      </a>
    </div>

    <!-- Right Item: Book Online Button -->
    <div style="text-align: right;">
      <a href="https://app.myridesync.com/quote?uid=grandlimousine" rel="noopener" target="_blank" style="background: #000000; color: #ffffff; text-decoration: none; padding: 6px 16px; font-weight: 700; font-size: 0.8rem; letter-spacing: 0.05em; text-transform: uppercase; border-radius: 2px; display: inline-block;">
        Book Online
      </a>
    </div>

  </div>
</div>
      <a href="#main" class="skip-link">Skip to content</a>
      <div class="container nav">
     {% if settings.identity.logo %}
    <!-- 1. CMS Uploaded Image Asset -->
    <a href="/" class="brand" aria-label="{{ settings.identity.logo_alt }}">
      <img src="/{{ settings.identity.logo }}" alt="{{ settings.identity.logo_alt }}" class="brand-logo" style="max-height: 40px; width: auto; display: block;">
    </a>
  {% else %}
    <!-- 2. Default Hardcoded Text Brand Fallback -->
    <a href="/" class="brand" aria-label="Bear Limo — home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span>BEAR&nbsp;LIMO</span>
    </a>
  {% endif %}
        <nav aria-label="Primary">
          <ul id="primary-nav" class="nav-list">
            <li><a href="/" aria-current="page">Home</a></li>
     <li class="has-dropdown">
  <button type="button" aria-haspopup="true" aria-expanded="false">Services</button>
  <div class="dropdown" role="menu" aria-label="Services Available">
    {% for service in collections.services %}
      <a href="/{{ service.fileSlug }}/" role="menuitem">{{ service.data.title }}</a>
    {% endfor %}
  </div>
</li>
         {% for item in settings.header_links %}
  <li>
    <a href="{{ item.url }}" {% if item.url == page.url %}aria-current="page"{% endif %}>
      {{ item.label }}
    </a>
  </li>
{% endfor %}
<li class="has-dropdown">
  <button type="button">Locations</button>
  <div class="dropdown" role="menu" aria-label="Service locations">
    {% for loc in collections.locations %}
      {# Strip out the .html extension for clean trailing slash paths #}
      <a href="/{{ loc.fileSlug }}/">{{ loc.data.title }}</a>
    {% else %}
      <span style="padding: 8px 12px; color: #999; font-size: 0.8rem;">No active cities loaded</span>
    {% endfor %}
  </div>
</li>
            
            <li class="nav-cta">
              <a  style = "color:#000000" class="btn btn-solid btn-sm" href="https://app.myridesync.com/quote?uid=grandlimousine" rel="noopener" target="_blank">Get a Quote</a>
            </li>
          </ul>
        </nav>
        <button class="hamburger" aria-label="Toggle menu" aria-controls="primary-nav" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>
    
